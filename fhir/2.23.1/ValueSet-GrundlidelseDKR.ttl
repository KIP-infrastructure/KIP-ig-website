     fhir:Narrative.status [ fhir:value "extensions" ] ;
     fhir:Narrative.div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: ValueSet GrundlidelseDKR</b></p><a name=\"GrundlidelseDKR\"> </a><a name=\"hcGrundlidelseDKR\"> </a><p>This value set includes codes based on the following rules:</p><ul><li>Include these codes as defined in <a href=\"CodeSystem-BasicDisorder.html\"><code>https://kip.rkkp.dk/fhir/CodeSystem/BasicDisorder</code></a><span title=\"Version is not explicitly stated, which means it is fixed to the version provided in this specification\"> version ?2.23.1</span><table class=\"none\"><tr><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td><td><b>Definition</b></td></tr><tr><td><a href=\"CodeSystem-BasicDisorder.html#BasicDisorder-arthrosis\">arthrosis</a></td><td>Primær (idiopatisk) artrose</td><td>Artrose</td></tr><tr><td><a href=\"CodeSystem-BasicDisorder.html#BasicDisorder-secondary_arthrosis\">secondary_arthrosis</a></td><td>Sek. artrose (f.eks. menisktomi)</td><td>Sekundær artrose</td></tr><tr><td><a href=\"CodeSystem-BasicDisorder.html#BasicDisorder-fracture_tibia_condyle\">fracture_tibia_condyle</a></td><td>Følger efter tibiakondylfraktur</td><td>Følger efter tibiakondylfraktur</td></tr><tr><td><a href=\"CodeSystem-BasicDisorder.html#BasicDisorder-fresh_fracture_tibia_condyle\">fresh_fracture_tibia_condyle</a></td><td>Frisk tibiakondylfraktur (inden for 14 dage)</td><td>Frisk tibiakondylfraktur</td></tr><tr><td><a href=\"CodeSystem-BasicDisorder.html#BasicDisorder-fracture_femoral_condyle\">fracture_femoral_condyle</a></td><td>Følger efter femurkondylfraktur</td><td>Følger efter tibiakondylfraktur</td></tr><tr><td><a href=\"CodeSystem-BasicDisorder.html#BasicDisorder-fresh_fracture_femoral_condyle\">fresh_fracture_femoral_condyle</a></td><td>Frisk femurkondylfraktur (inden for 14 dage)</td><td>Frisk femurkondylfraktur</td></tr><tr><td><a href=\"CodeSystem-BasicDisorder.html#BasicDisorder-fracture_patella\">fracture_patella</a></td><td>Følger efter patellafraktur</td><td>Følger efter patellafraktur</td></tr><tr><td><a href=\"CodeSystem-BasicDisorder.html#BasicDisorder-rheumatoid\">rheumatoid</a></td><td>Reumatoid artrit</td><td>Reumatoid artrit</td></tr><tr><td><a href=\"CodeSystem-BasicDisorder.html#BasicDisorder-other_arthritis\">other_arthritis</a></td><td>Følger efter anden artrit</td><td>Anden artrit</td></tr><tr><td><a href=\"CodeSystem-BasicDisorder.html#BasicDisorder-hemophilia\">hemophilia</a></td><td>Hæmofili</td><td>Hæmofili</td></tr><tr><td><a href=\"CodeSystem-BasicDisorder.html#BasicDisorder-primary_tumor\">primary_tumor</a></td><td>Tumor - primær</td><td>Primær tumor</td></tr><tr><td><a href=\"CodeSystem-BasicDisorder.html#BasicDisorder-metastases\">metastases</a></td><td>Tumor - metastase</td><td>Metastaser</td></tr><tr><td><a href=\"CodeSystem-BasicDisorder.html#BasicDisorder-osteonecrosis\">osteonecrosis</a></td><td>Osteonekrose</td><td>Osteonekrose</td></tr></table></li><li>Include these codes as defined in <a href=\"CodeSystem-GenericValues.html\"><code>https://kip.rkkp.dk/fhir/CodeSystem/GenericValues</code></a><span title=\"Version is not explicitly stated, which means it is fixed to the version provided in this specification\"> version ?2.23.1</span><table class=\"none\"><tr><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td><td><b>Definition</b></td></tr><tr><td><a href=\"CodeSystem-GenericValues.html#GenericValues-other\">other</a></td><td>Andet</td><td>Other - used to choose unspecific value not in a valueset</td></tr></table></li></ul></div>"
