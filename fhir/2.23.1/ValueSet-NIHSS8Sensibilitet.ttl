  fhir:DomainResource.text [
     fhir:Narrative.status [ fhir:value "extensions" ] ;
     fhir:Narrative.div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: ValueSet NIHSS8Sensibilitet</b></p><a name=\"NIHSS8Sensibilitet\"> </a><a name=\"hcNIHSS8Sensibilitet\"> </a><ul><li>Include these codes as defined in <a href=\"CodeSystem-NIHSS8Sensory.html\"><code>https://kip.rkkp.dk/fhir/CodeSystem/NIHSS8Sensory</code></a><span title=\"Version is not explicitly stated, which means it is fixed to the version provided in this specification\"> version ?2.23.1</span><table class=\"none\"><tr><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td><td><b>Definition</b></td></tr><tr><td><a href=\"CodeSystem-NIHSS8Sensory.html#NIHSS8Sensory-0\">0</a></td><td>0 = Normal sensibilitet for stik</td><td>Normal; no sensory loss.</td></tr><tr><td><a href=\"CodeSystem-NIHSS8Sensory.html#NIHSS8Sensory-1\">1</a></td><td>1 = Let til moderat nedsat sensibilitet for prik</td><td>Mild-to-moderate sensory loss; patient feels pinprick is less sharp or is dull on the affected side; or there is a loss of superficial pain with pinprick, but patient is aware of being touched.</td></tr><tr><td><a href=\"CodeSystem-NIHSS8Sensory.html#NIHSS8Sensory-2\">2</a></td><td>2 = Svær til total sensibilitetstab</td><td>Severe to total sensory loss; patient is not aware of being touched in the face, arm, and leg.</td></tr></table></li></ul></div>"
  ] ;
