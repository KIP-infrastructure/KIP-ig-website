     fhir:Narrative.status [ fhir:value "extensions" ] ;
     fhir:Narrative.div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: ValueSet AKFravalgt</b></p><a name=\"AKFravalgt\"> </a><a name=\"hcAKFravalgt\"> </a><p>This value set includes codes based on the following rules:</p><ul><li>Include these codes as defined in <a href=\"CodeSystem-ACTherapyNotGiven.html\"><code>https://kip.rkkp.dk/fhir/CodeSystem/ACTherapyNotGiven</code></a><span title=\"Version is not explicitly stated, which means it is fixed to the version provided in this specification\"> version ?2.23.1</span><table class=\"none\"><tr><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td><td><b>Definition</b></td></tr><tr><td><a href=\"CodeSystem-ACTherapyNotGiven.html#ACTherapyNotGiven-activebleeding\">activebleeding</a></td><td>Aktiv blødning</td><td>Aktiv blødning</td></tr><tr><td><a href=\"CodeSystem-ACTherapyNotGiven.html#ACTherapyNotGiven-intracerebralhaemorrhage\">intracerebralhaemorrhage</a></td><td>Nylig intracerebral blødning</td><td>Nylig intracerebral blødning</td></tr><tr><td><a href=\"CodeSystem-ACTherapyNotGiven.html#ACTherapyNotGiven-hypertension\">hypertension</a></td><td>Ukontrolleret hypertension (≥160 mmHg)</td><td>Ukontrolleret hypertension (≥160 mmHg)</td></tr><tr><td><a href=\"CodeSystem-ACTherapyNotGiven.html#ACTherapyNotGiven-diathesis\">diathesis</a></td><td>Hæmoragisk diatese</td><td>Hæmoragisk diatese</td></tr><tr><td><a href=\"CodeSystem-ACTherapyNotGiven.html#ACTherapyNotGiven-othertreatment\">othertreatment</a></td><td>Anden behandling (aurikellukning, LMWH i terapeutiske doser)</td><td>Anden behandling (aurikellukning, LMWH i terapeutiske doser)</td></tr><tr><td><a href=\"CodeSystem-ACTherapyNotGiven.html#ACTherapyNotGiven-dementia\">dementia</a></td><td>Svær demens</td><td>Svær demens</td></tr><tr><td><a href=\"CodeSystem-ACTherapyNotGiven.html#ACTherapyNotGiven-reducedfunctionlevel\">reducedfunctionlevel</a></td><td>Betydelig reduceret funktionsniveau (mRS ≥4)</td><td>Betydelig reduceret funktionsniveau (mRS ≥4)</td></tr><tr><td><a href=\"CodeSystem-ACTherapyNotGiven.html#ACTherapyNotGiven-lifespanbelow3months\">lifespanbelow3months</a></td><td>Forventet livslængde under 3 måneder</td><td>Forventet livslængde under 3 måneder</td></tr><tr><td><a href=\"CodeSystem-ACTherapyNotGiven.html#ACTherapyNotGiven-nopatientconsent\">nopatientconsent</a></td><td>Manglende patientsamtykke</td><td>Manglende patientsamtykke</td></tr></table></li><li>Include these codes as defined in <a href=\"CodeSystem-GenericValues.html\"><code>https://kip.rkkp.dk/fhir/CodeSystem/GenericValues</code></a><span title=\"Version is not explicitly stated, which means it is fixed to the version provided in this specification\"> version ?2.23.1</span><table class=\"none\"><tr><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td><td><b>Definition</b></td></tr><tr><td><a href=\"CodeSystem-GenericValues.html#GenericValues-other\">other</a></td><td>Anden årsag</td><td>Other - used to choose unspecific value not in a valueset</td></tr></table></li></ul></div>"
  ] ;
