<https://kip.rkkp.dk/fhir/ValueSet/NYHA> a fhir:ValueSet ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:Resource.id [ fhir:value "NYHA"] ;
  fhir:DomainResource.text [
     fhir:Narrative.status [ fhir:value "extensions" ] ;
     fhir:Narrative.div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: ValueSet NYHA</b></p><a name=\"NYHA\"> </a><a name=\"hcNYHA\"> </a><ul><li>Include these codes as defined in <a href=\"CodeSystem-NYHA.html\"><code>https://kip.rkkp.dk/fhir/CodeSystem/NYHA</code></a><span title=\"Version is not explicitly stated, which means it is fixed to the version provided in this specification\"> version ?2.23.1</span><table class=\"none\"><tr><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td><td><b>Definition</b></td></tr><tr><td><a href=\"CodeSystem-NYHA.html#NYHA-NYHAI\">NYHAI</a></td><td>NYHA klasse I</td><td>No limitation of physical activity. Ordinary physical activity does not cause undue fatigue, palpitation, dyspnea (shortness of breath).</td></tr><tr><td><a href=\"CodeSystem-NYHA.html#NYHA-NYHAII\">NYHAII</a></td><td>NYHA klasse II</td><td>Slight limitation of physical activity. Comfortable at rest. Ordinary physical activity results in fatigue, palpitation, dyspnea (shortness of breath).</td></tr><tr><td><a href=\"CodeSystem-NYHA.html#NYHA-NYHAIII\">NYHAIII</a></td><td>NYHA klasse III</td><td>Marked limitation of physical activity. Comfortable at rest. Less than ordinary activity causes fatigue, palpitation, or dyspnea.</td></tr><tr><td><a href=\"CodeSystem-NYHA.html#NYHA-NYHAIV\">NYHAIV</a></td><td>NYHA klasse IV</td><td>Unable to carry on any physical activity without discomfort. Symptoms of heart failure at rest. If any physical activity is undertaken, discomfort increases.</td></tr></table></li></ul></div>"
  ] ;
