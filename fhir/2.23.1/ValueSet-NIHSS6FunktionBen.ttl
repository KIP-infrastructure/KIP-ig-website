  fhir:DomainResource.text [
     fhir:Narrative.status [ fhir:value "extensions" ] ;
     fhir:Narrative.div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: ValueSet NIHSS6FunktionBen</b></p><a name=\"NIHSS6FunktionBen\"> </a><a name=\"hcNIHSS6FunktionBen\"> </a><ul><li>Include these codes as defined in <a href=\"CodeSystem-NIHSS6MotorLeg.html\"><code>https://kip.rkkp.dk/fhir/CodeSystem/NIHSS6MotorLeg</code></a><span title=\"Version is not explicitly stated, which means it is fixed to the version provided in this specification\"> version ?2.23.1</span><table class=\"none\"><tr><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td><td><b>Definition</b></td></tr><tr><td><a href=\"CodeSystem-NIHSS6MotorLeg.html#NIHSS6MotorLeg-0\">0</a></td><td>0 = Ingen nedsynkning</td><td>No drift; leg holds 30-degree position for full 5 seconds.</td></tr><tr><td><a href=\"CodeSystem-NIHSS6MotorLeg.html#NIHSS6MotorLeg-1\">1</a></td><td>1 = Nedsynkning, men ikke til underlag</td><td>Drift; leg falls by the end of the 5-second period but does not hit bed.</td></tr><tr><td><a href=\"CodeSystem-NIHSS6MotorLeg.html#NIHSS6MotorLeg-2\">2</a></td><td>2 = Nogen kraft mod tyngde</td><td>Some effort against gravity; leg falls to bed by 5 seconds, but has some effort against gravity.</td></tr><tr><td><a href=\"CodeSystem-NIHSS6MotorLeg.html#NIHSS6MotorLeg-3\">3</a></td><td>3 = Falder til underlag</td><td>No effort against gravity; leg falls to bed immediately.</td></tr><tr><td><a href=\"CodeSystem-NIHSS6MotorLeg.html#NIHSS6MotorLeg-4\">4</a></td><td>4 = Ingen bevægelse</td><td>No movement.</td></tr><tr><td><a href=\"CodeSystem-NIHSS6MotorLeg.html#NIHSS6MotorLeg-UN\">UN</a></td><td>5 = Kan ikke testes (amputation/stivgjort led/andet)</td><td>Amputation or joint fusion, explain:</td></tr></table></li></ul></div>"
  ] ;
